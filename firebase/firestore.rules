rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userRef() {
      return /databases/$(database)/documents/Users/$(request.auth.uid);
    }
    function isInList(list, item) {
      return item in list;
    }

    // Post likes: allow only the authenticated user to like/unlike a post by
    // adding/removing their own user reference in Posted_likeby.
    match /Post/{postId} {
      allow read: if true;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['Posted_likeby'])
        && (
          // Like (adds only current user ref)
          (
            request.resource.data.Posted_likeby.size() == resource.data.Posted_likeby.size() + 1 &&
            !isInList(resource.data.Posted_likeby, userRef()) &&
            isInList(request.resource.data.Posted_likeby, userRef())
          ) ||
          // Unlike (removes only current user ref)
          (
            request.resource.data.Posted_likeby.size() == resource.data.Posted_likeby.size() - 1 &&
            isInList(resource.data.Posted_likeby, userRef()) &&
            !isInList(request.resource.data.Posted_likeby, userRef())
          )
        );
    }
  }
}
